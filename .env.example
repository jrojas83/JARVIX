# ─────────────────────────────────────────────────────────────
# Jarvis v5 — Variables de entorno
# Copia este archivo como .env y rellena tus claves:
#   cp .env.example .env
#
# ⚠️  El archivo .env NUNCA se sube a Git.
# ─────────────────────────────────────────────────────────────

# ── IAs en línea ──────────────────────────────────────────────
# GROQ: gratis, 14.400 req/día → https://console.groq.com
GROQ_API_KEY=

# GEMINI: gratis permanente, 1M tokens/mes → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ANTHROPIC/CLAUDE: $5 créditos iniciales → https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Clima ─────────────────────────────────────────────────────
# OpenWeatherMap: gratis → https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── Preferencias personales ───────────────────────────────────
# Ciudad por defecto para el clima (formato: Ciudad,PAIS_ISO)
CIUDAD_DEFAULT=Cali,CO

# IA preferida: auto | groq | gemini | anthropic | ollama
# "auto" prueba en orden: Groq → Gemini → Anthropic → Ollama
IA_PREFERIDA=auto

# Modelo Ollama local por defecto
MODELO_OLLAMA=qwen2.5:3b

# Palabra de activación para modo espera
PALABRA_ACTIVACION=jarvis

# ── Perfil de usuario ─────────────────────────────────────────
# Nombre para saludos personalizados ("Buenos días, Andrés")
NOMBRE_USUARIO=

# Ciudad por defecto ya definida arriba (CIUDAD_DEFAULT)

# Horario laboral en formato HH-HH (24h). Jarvis adapta saludos y contexto.
# Ejemplo: 8-18 significa que trabajas de 8:00 a 18:00
HORARIO_TRABAJO=8-18

# Género gramatical para el asistente: masculino | femenino
# Afecta frases como "listo" vs "lista", "activo" vs "activa"
GENERO_ASISTENTE=masculino
